{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "caffeinate -dims &"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "killall caffeinate 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
